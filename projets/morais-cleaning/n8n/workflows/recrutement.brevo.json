      "position": [-460, 140],
      "id": "airtable-recrutement",
      "credentials": {
        "airtableTokenApi": {
          "id": "REPLACE_WITH_YOUR_AIRTABLE_CRED_ID",
          "name": "Airtable Personal Access Token"
        }
      }
