      "id": "normalize-recrutement"
    },
    {
      "parameters": {
        "operation": "create",
        "base": {
          "__rl": true,
          "value": "appVuLTqzGQilUXGw",
          "mode": "list",
          "cachedResultName": "Morais Cleaning -CRM",
          "cachedResultUrl": "https://airtable.com/appVuLTqzGQilUXGw"
        },
        "table": {
          "__rl": true,
          "value": "REPLACE_WITH_RECRUTEMENT_TABLE_ID",
          "mode": "list",
          "cachedResultName": "recrutement",
          "cachedResultUrl": "https://airtable.com/appVuLTqzGQilUXGw"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Nom": "={{$json.nom}}",
            "Email": "={{$json.email}}",
            "Téléphone": "={{$json.telephone}}",
            "Poste": "={{$json.poste}}",
