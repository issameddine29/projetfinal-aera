    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/smtp/email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "api-key", "value": "={{$env.BREVO_API_KEY || ''}}"},
            {"name": "Content-Type", "value": "application/json"},
            {"name": "accept", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{(() => {\n  const n = $node['Normalize Data'].json;\n  const atts = ($binary && $binary.cv) ? [{\n    name: $binary.cv.fileName || 'cv',\n    content: $binary.cv.data\n  }] : [];\n  return {\n    sender: { name: 'Morais Cleaning', email: 'recrutement@morais-cleaning.com' },\n    to: [{ email: 'recrutement@morais-cleaning.com' }],\n    replyTo: { email: n.email, name: n.nom },\n    subject: `Nouvelle candidature – ${n.nom}`,\n    htmlContent: `<h2>Nouvelle candidature</h2>\n<p><strong>Nom :</strong> ${n.nom}</p>\n<p><strong>Email :</strong> ${n.email}</p>\n<p><strong>Téléphone :</strong> ${n.telephone}</p>\n<p><strong>Poste :</strong> ${n.poste}</p>\n<p><strong>Message :</strong></p>\n<p>${n.message}</p>\n<hr>\n<p><strong>Page :</strong> ${n.page}</p>\n<p><strong>Date :</strong> ${n.timestamp}</p>`,\n    attachments: atts\n  };\n})()}}"
      },
      "name": "Brevo - Email RH (avec CV)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-180, 140],
      "id": "brevo-rh-recrutement"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/smtp/email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "api-key", "value": "={{$env.BREVO_API_KEY || ''}}"},
            {"name": "Content-Type", "value": "application/json"},
            {"name": "accept", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{({\n  sender: { name: 'Morais Cleaning', email: 'recrutement@morais-cleaning.com' },\n  to: [{ email: $node['Normalize Data'].json.email }],\n  subject: 'Confirmation de réception de votre candidature',\n  htmlContent: `<p>Bonjour ${$node['Normalize Data'].json.nom || ''},</p>\n<p>Nous avons bien reçu votre candidature. Nous reviendrons vers vous dès que possible.</p>\n<p>Merci,<br>Morais Cleaning</p>`\n})}}"
      },
      "name": "Brevo - Email Candidat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [120, 140],
      "id": "brevo-candidat"
    },
